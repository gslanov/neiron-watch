<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>Neiron</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIconName</key>
	<string>AppIcon</string>
	<key>CFBundleIdentifier</key>
	<string>com.openclaw.neiron.watchkitapp</string>
	<key>CFBundleName</key>
	<string>Neiron</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Neiron connects to your local OpenClaw server to process voice commands.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Neiron needs microphone access to listen for your voice commands and record questions.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Neiron uses speech recognition to detect the wake word and transcribe your questions.</string>
	<key>WKApplication</key>
	<true/>
</dict>
</plist>
